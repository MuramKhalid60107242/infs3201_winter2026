<h1>{{employee.name}}</h1>
<p>{{employee.phone}}</p>

{{#if employee.photoUrl}}
<p><img src="{{employee.photoUrl}}" alt="{{employee.name}}" width="200"></p>
{{/if}}

{{#if (eq user.role "admin")}}
<a href="/editEmployee?empId={{employee._id}}">Edit</a>
{{/if}}


<table border="1">
<tr><th>Date</th><th>Start</th><th>End</th></tr>
{{#each shifts}}
<tr><td>{{date}}</td><td>{{startTime}}</td><td>{{endTime}}</td></tr>
{{/each}}
</table>
