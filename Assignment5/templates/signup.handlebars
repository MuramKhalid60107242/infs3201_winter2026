<h1>Create Account</h1>
{{#if message}}<p style="color:red">{{message}}</p>{{/if}}
<form method="POST" action="/signup">
<label>Username</label><br>
<input name="username" placeholder="Choose a username"><br><br>
<label>Email Address</label><br>
<input name="email" type="email" placeholder="Your email"><br><br>
<label>Password</label><br>
<input name="password" type="password" placeholder="Choose a password"><br><br>
<label>Confirm Password</label><br>
<input name="confirmPassword" type="password" placeholder="Repeat your password"><br><br>
<button type="submit">Create Account</button>
</form>
<p>Already registered? <a href="/login">Sign in</a></p>
