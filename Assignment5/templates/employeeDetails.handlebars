<h1>{{employee.name}}</h1>
<p>Phone: {{employee.phone}}</p>

<a href="/editEmployee?empId={{employee._id}}">Edit Profile</a> |
<a href="/employee/{{employee._id}}/upload">Documents</a>

<h2>Shift Schedule</h2>
<table border="1">
<thead><tr><th>Date</th><th>Start Time</th><th>End Time</th></tr></thead>
<tbody>
{{#each shifts}}
<tr><td>{{date}}</td><td>{{startTime}}</td><td>{{endTime}}</td></tr>
{{/each}}
</tbody>
</table>

<br><a href="/">Back to Directory</a>
